import java.util.*;
public class Main{
  public static void main(String[] args){
    Scanner sc = new Scanner(System.in);
    int N = sc.nextInt();
    int M = sc.nextInt();
    int max_op = 0,x=0;
    while(M!=0){
      x = N%M;
      M = x;
      max_op++;
    }
    System.out.println(max_op);
  }
}
